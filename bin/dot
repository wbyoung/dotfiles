#!/usr/bin/env bash
# vim: set ft=bash :

cd "$(dirname "$0")/.."
shopt -s extglob

declare -r ARGS=("$@")
declare -r CONFIG_FILE="${PWD}/config.json"
declare -A CONFIG
declare -A OPTIONS

if [ -t 1 ] && (
  (
  [ -x "$(command -v tput)" ] \
    && [ -n "$(tput colors)" ] \
    && [ "$(tput colors)" -ge 8 ] \
  ) \
  || [ "$TERM" == *color* ] \
  || [ -n "$COLORTERM" ] \
); then
    export CLICOLOR=true
fi

{
  [ "${CLICOLOR:-}" = "true" ] || [ "${CLICOLOR:-}" = "1" ] && \
    tty_only() { printf "${1}"; } || \
    tty_only() { printf ""; }

  cli_color() { tty_only "\033[0;${1}m"; }

  RED=$(cli_color "31")
  GREEN=$(cli_color "32")
  YELLOW=$(cli_color "33")
  BLUE=$(cli_color "34")
  MAGENTA=$(cli_color "35")
  CYAN=$(cli_color "36")
  BOLD=$(tty_only "\033[1m")
  RESET=$(tty_only "\033[0m")
  HIDE_CURSOR=$(tty_only "\x1b[?25l")
  SHOW_CURSOR=$(tty_only "\x1b[?25h")
  CURSOR_UP_ONE_LINE=$(tty_only "\x1b[1A")
  CURSOR_DOWN_ONE_LINE=$(tty_only "\x1b[1B")
  CLEAR_CURRENT_LINE=$(tty_only "\x1b[2K")
  CLEAR_LAST_LINE=$(tty_only "${CURSOR_UP_ONE_LINE}${CLEAR_CURRENT_LINE}")

  unset -f tty_only;
  unset -f cli_color;
}

dot-main() {
  script-init "$@"
  store-config # store prior to install in case things fail
  install-all
  store-config
}

interrupt-cleanup() {
  exit 1
}

install-all() {
  self-update
  want-to-install "zsh config" && install-zsh-config
  want-to-install "vim config" && install-vim-config
  want-to-install "git config" && install-git-config
  want-to-install "gist commands" && install-gist-commands
  want-to-install "vscode config" && install-vscode-config
  want-to-install "tmux config" && install-tmux-config
  want-to-install "miscellaneous config" && install-miscellaneous-config
  is-fedora-linux && want-to-install "fedora settings" "and apps" && run-fedora-setup
  is-alpine-linux && want-to-install "alpine settings" "and apps" && run-alpine-setup
  is-darwin && want-to-install "homebrew" && install-homebrew
  is-darwin && want-to-install "osx settings" "and apps" && run-osx-setup
}

self-update() {
  if [ -n "$_DOTFILES_SELFUPDATE_COMPLETE" ]; then
    return
  fi

  log-info "[self-update]"
  run-cmd "git pull origin -q --ff-only"

  # in case anything within this script changed during the pull, re-exec the
  # script (while skipping updating again).
  _DOTFILES_SELFUPDATE_COMPLETE=1 exec "${BASH_SOURCE[0]}" "${ARGS[@]}"
}

install-zsh-config() {
  log-info "[zsh]"
  install-dotfiles "." "zshrc"
}

install-vim-config() {
  log-info "[vim]"
  install-dotfiles "." "vim/vimrc"
  install-dotfiles ".config/nvim/" "vim/nvim/*"
}

install-git-config() {
  log-info "[git]"
  install-dotfiles "." "git/*"
  is-config-set "git-sshcmd" && run-cmd setup-git-sshcmd
  is-config-set "git-gpgssh" && run-cmd setup-git-gpgssh
}

install-gist-commands() {
  log-info "[gist]"
  run-cmd setup-gist-commands
}

install-vscode-config() {
  log-info "[vscode]"
  install-dotfiles ".config/Code/User/" "vscode/*"
}

install-tmux-config() {
  log-info "[tmux]"
  install-dotfiles "." "tmux/*"
}

install-miscellaneous-config() {
  log-info "[misc]"
  install-dotfiles "." "misc/*"
}

run-fedora-setup() {
  log-info "[fedora]"
  log-detail "[exec] fedora/setup"
  fedora/setup "${ARGS[@]}"
}

run-alpine-setup() {
  log-info "[alpine]"
  log-detail "[exec] alpine/setup"
  alpine/setup "${ARGS[@]}"
}

run-osx-setup() {
  log-info "[osx]"
  log-detail "[exec] osx/setup"
  osx/setup "${ARGS[@]}"
}

install-homebrew() {
  log-info "[homebrew]"

  run-cmd which brew
  [ $? -eq 0 ] || run-cmd install-homebrew-via-curl
  run-cmd brew update
  run-cmd brew install -q cloc coreutils git gpg grc hub jq node python python3 tmux terminal-notifier the_silver_searcher zsh reattach-to-user-namespace vim
  run-cmd brew install -q --cask --appdir=/Applications flux google-chrome visual-studio-code
  run-cmd brew install -q --no-quarantine grishka/grishka/neardrop
}

install-homebrew-via-curl() {
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

install-dotfiles() {
  local target_prefix="${1}"
  local target_prefix_nodirs="${target_prefix//\//}"
  local target_prefix_dir_count=$((${#target_prefix} - ${#target_prefix_nodirs}))
  local relative_to_home=""
  for (( i=0; i<$target_prefix_dir_count; i++ )); do
    relative_to_home+="../"
  done

  shift

  [ -d "${HOME}/${target_prefix}" ] \
    || run-cmd mkdir -p "${HOME}/${target_prefix}"

  if [ "${target_prefix}" = "." ]; then
    target_prefix=""
  fi

  for file in $@; do
    run-cmd link-dotfile "${file}" "${target_prefix}"
  done
}

link-dotfile() {
  local file="$1"
  local target_prefix="${2:-.}"
  local name=$(basename $file)
  local basepath=$([ "$(dirname "$PWD")" == "$HOME" ] \
      && (echo "$relative_to_home$(basename "$PWD")") \
      || echo "$PWD")
  local source="$basepath/$file"
  local target="$HOME/$target_prefix$name"
  local overwrite_reason=""

  [ -d "${HOME}/${target_prefix}" ] \
    || mkdir -p "${HOME}/${target_prefix}"

  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" != "$source" ]; then
      overwrite_reason="wrong symlink"
    fi
  elif [ -e "$target" ]; then
    overwrite_reason="not a symlink"
  fi

  if [ -n "$overwrite_reason" ]; then
    log-warning "overwriting ${target} (${overwrite_reason}), leaving original at ${target}.backup"
    mv "$target" "$target.backup"
  fi

  ln -nfs "${source}" "${target}"
}

run-cmd() {
  log-detail "[exec] ${*}"

  if [ "${OPTIONS["dry-run"]}" != "yes" ]; then
    $@
  fi
}

log-info() {
  printf "${CYAN}${*}${RESET}\n"
}

log-detail() {
  printf "${MAGENTA}${*}${RESET}\n"
}

log-warning () {
  printf "${YELLOW}${*}${RESET}\n" 1>&2
}

log-error () {
  printf "${RED}${*}${RESET}\n" 1>&2
}

is-fedora-linux() {
  [ -f /etc/os-release ] \
    && [ "$(source /etc/os-release && echo $ID)" == "fedora" ] \
    && return 0 || return 1
}

is-alpine-linux() {
  [ -f /etc/os-release ] \
    && [ "$(source /etc/os-release && echo $ID)" == "alpine" ] \
    && return 0 || return 1
}

is-darwin() {
  [ "$OSTYPE" == darwin* ] && return 0 || return 1
}

is-dry-run() {
  is-option-set "dry-run"
}

is-option-set() {
  [ "${OPTIONS[${1}]}" == "yes" ] \
    && return 0 || return 1
}

is-config-set() {
  [ "${CONFIG[${1}]}" == "yes" ] \
    && return 0 || return 1
}

has-jq() {
  [ -x "$(command -v jq)" ]
}

want-to-install() {
  local topic="${1}"
  local message_details="${2}"
  local config_key="${topic// /-}"
  local config_value="${CONFIG[${config_key}]}"
  local result=""
  local install_prompt="install ${topic}"

  if [ -n "$message_details" ]; then
    install_prompt+=" (${message_details})"
  fi

  if [ -n "$config_value" ]; then
    is-config-set "$config_key"
    result=$?
  elif is-option-set "prompt"; then
    while [ true ]; do
      printf "${CYAN}install ${topic}? ${MAGENTA}[y/n] ${RESET}"
      read response
      case "$response" in
          y)
              result=0
              ;;
          n)
              result=1
              ;;
      esac
    done
  elif is-option-set "choose"; then
    result=1 # for `--choose` the default is that nothing is installed
  else
    result=0 # the default is that everything is installed
  fi

  CONFIG["$config_key"]="$([ "${result}" -eq 0 ] && echo yes || echo no)"

  return $result
}

script-init() {
  trap 'interrupt-cleanup' SIGINT
  load-config
  parse-options "$@"
}

load-config() {
  if ! [ -f "$CONFIG_FILE" ]; then
    return
  fi
  if [ -f "$CONFIG_FILE" ] && ! has-jq; then
    log-warning "no \`jq\` found, skipping loading of .dotfiles/config.json"
    return
  fi
  while IFS="=" read -r key value; do
    CONFIG["$key"]="$value"
  done < <(jq -r 'to_entries[] | "\(.key)=\(.value)"' "$CONFIG_FILE")
}

store-config() {
  is-dry-run && return
  has-jq || { log-warning "no \`jq\` found, .dotfiles/config.json not saved"; return; }

  args=()
  for i in "${!CONFIG[@]}"; do
    args+=("--arg" "$i" "${CONFIG[$i]}")
  done
  jq --null-input --sort-keys "${args[@]}" '$ARGS.named' > "$CONFIG_FILE"
}

parse-flag() {
  [ "${1}" == "--no"* ] && echo "no" || echo "yes"
}

parse-options() {
  while [ $# -ne 0 ]; do
    case "${1}" in
      -p|--?(no)prompt)
        OPTIONS["prompt"]=$(parse-flag "${1}")
        shift
        ;;
      -c|--choose)
        OPTIONS["choose"]="yes"
        shift
        ;;
      -d|--dry-run)
        OPTIONS["dry-run"]="yes"
        shift
        ;;
      --?(no)zsh-config)
        CONFIG["zsh-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)vim-config)
        CONFIG["vim-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)git-config)
        CONFIG["git-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)git-config-sshcmd)
        CONFIG["git-sshcmd"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)git-config-gpgssh)
        CONFIG["git-gpgssh"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)gist-commands)
        CONFIG["gist-commands"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)vscode-config)
        CONFIG["vscode-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)tmux-config)
        CONFIG["tmux-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)miscellaneous-config)
        CONFIG["miscellaneous-config"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)fedora-settings)
        CONFIG["fedora-settings"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)alpine-settings)
        CONFIG["alpine-settings"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)osx-settings)
        CONFIG["osx-settings"]=$(parse-flag "${1}")
        shift
        ;;
      --?(no)homebrew)
        CONFIG["homebrew"]=$(parse-flag "${1}")
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        log-error "invalid argument: ${1}"
        usage >&2
        exit 1
        ;;
    esac
  done
}

usage() {
  echo "Usage:"
  echo "	dot [options]"
  echo
  echo "Options:"
  echo "	-p, --[no-]prompt	Prompt to install each item"
  echo "	-c, --choose	Require opting in to install each item"
  echo "	-d, --dry-run	Do not actually run commands"
  echo "	--[no-]fedora-settings"
  echo "	--[no-]alpine-settings"
  echo "	--[no-]git-config-gpgssh"
  echo "	--[no-]git-config-sshcmd"
  echo "	--[no-]git-config"
  echo "	--[no-]gist-commands"
  echo "	--[no-]homebrew"
  echo "	--[no-]miscellaneous-config"
  echo "	--[no-]osx-settings"
  echo "	--[no-]tmux-config"
  echo "	--[no-]vim-config"
  echo "	--[no-]vscode-config"
  echo "	--[no-]zsh-config"
  echo "	--help"
}

if [ "${BASH_SOURCE[0]}" == "${0}" ]; then
  dot-main "$@"
fi
